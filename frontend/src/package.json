{
  "name": "personal-blog",
  "repository": "https://github.com/mota-lhd/blog.git",
  "author": "Elmouatassim.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev:css": "postcss ./assets/app.css -o ./assets/main.css --watch",
    "dev:server": "hugo server --config ./config.yml --source . --gc --buildDrafts --openBrowser",
    "dev": "bun dev:css & bun dev:server",
    "build:css": "postcss ./assets/app.css -o ./assets/main.css",
    "build:generate": "hugo --config ./config.yml --gc --minify --source . --destination public"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^11.1.2",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.18"
  }
}
